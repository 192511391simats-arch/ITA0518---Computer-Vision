import cv2
import numpy as np
import matplotlib.pyplot as plt

# Create high-frequency grid pattern
img = np.zeros((200, 200), dtype=np.uint8)
img[::5, :] = 255
img[:, ::5] = 255

# Apply Gaussian Blur
blurred = cv2.GaussianBlur(img, (5, 5), 0)

# Downsample
downsampled = cv2.resize(blurred, (40, 40), interpolation=cv2.INTER_AREA)

# Aliased version
bad_downsample = cv2.resize(img, (40, 40), interpolation=cv2.INTER_NEAREST)

# Display
plt.figure(figsize=(8,4))
plt.subplot(121)
plt.imshow(bad_downsample, cmap='gray')
plt.title('Aliased (Jagged)')

plt.subplot(122)
plt.imshow(downsampled, cmap='gray')
plt.title('Anti-Aliased (Smooth)')

plt.show()

import cv2
import numpy as np
import matplotlib.pyplot as plt

# Step 1: Create a high-frequency grid pattern
img = np.zeros((200, 200), dtype=np.uint8)

# Draw white grid lines every 5 pixels
img[::5, :] = 255
img[:, ::5] = 255

# Step 2: Create an aliased image
# Direct downsampling without filtering
aliased = cv2.resize(
    img,
    (40, 40),
    interpolation=cv2.INTER_NEAREST
)

# Step 3: Apply Gaussian Blur (Anti-Aliasing Filter)
blurred = cv2.GaussianBlur(
    img,
    (5, 5),
    0
)

# Step 4: Downsample after filtering
anti_aliased = cv2.resize(
    blurred,
    (40, 40),
    interpolation=cv2.INTER_AREA
)

# Step 5: Display results
plt.figure(figsize=(8, 4))

plt.subplot(1, 2, 1)
plt.imshow(aliased, cmap='gray')
plt.title("Aliased (Jagged)")
plt.axis('off')

plt.subplot(1, 2, 2)
plt.imshow(anti_aliased, cmap='gray')
plt.title("Anti-Aliased (Smooth)")
plt.axis('off')

plt.tight_layout()
plt.show()


